# Copy this file to .env.local (for local dev) or set these as environment
# variables on your hosting platform. Never commit filled-in values.

# ─── Site ─────────────────────────────────────────────────────────────────
# Public origin used to build absolute URLs (e.g. magic links inside emails).
# Vercel Production: https://sataniresearchcentre.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── SMTP — /api/contact, /api/newsletter, /api/lab-access ────────────────
# Hostinger mailboxes: host=smtp.hostinger.com, port=465 (TLS).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your-mailbox@yourdomain.com
SMTP_PASS=your-mailbox-password

# ─── Lab Tools access gate ────────────────────────────────────────────────
# 32+ byte random string used to sign/verify every JWT (decision, launch,
# session, revoke tokens). Rotate by generating a fresh value.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-long-random-string

# Inbox that receives approve/deny requests and revoke links.
LAB_ACCESS_ADMIN_EMAIL=connect@sataniresearchcentre.com

# Destination LabCalc instance. Approved users land here after launch.
LABCALC_URL=https://lab-calc-engine.vercel.app

# ─── Persistent storage (production) ──────────────────────────────────────
# Provided automatically by the Upstash Redis Vercel integration.
# When unset (local dev), storage falls back to .lab-access-data.json
# in the project root (gitignored).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
