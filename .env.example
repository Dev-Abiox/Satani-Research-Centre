# Copy this file to .env.local (for local dev) or set these as environment
# variables on your hosting platform. Never commit filled-in values.

# SMTP — used by /api/contact and /api/newsletter (nodemailer).
# For Hostinger mailboxes: host=smtp.hostinger.com, port=465, secure=true (set in code).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your-mailbox@yourdomain.com
SMTP_PASS=your-mailbox-password
